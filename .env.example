APP_NAME="Investment Intelligence"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Database ─────────────────────────────────────────────────────────────────
# MySQL (dev/prod)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=investment_intelligence
DB_USERNAME=root
DB_PASSWORD=

# ── Sessions ─────────────────────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ── Queue ────────────────────────────────────────────────────────────────────
# Uses MySQL database driver by default — no Redis required.
# Set to "redis" for production if Redis is available.
QUEUE_CONNECTION=database

# ── Cache ────────────────────────────────────────────────────────────────────
# Use "file" or "database" for setups without Redis.
# Use "redis" for production.
CACHE_STORE=file

# ── Redis (optional) ─────────────────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Mail ─────────────────────────────────────────────────────────────────────
# Mailpit is available at http://localhost:8025 in the Docker setup.
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@investment.local"
MAIL_FROM_NAME="${APP_NAME}"

# ── Filesystem / Broadcasting ────────────────────────────────────────────────
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# ── Scoring Engine ────────────────────────────────────────────────────────────
# Model version tag stored with each scoring run.
SCORING_MODEL_VERSION=1.0.0

# Automatic daily scoring via Laravel scheduler.
# Set SCORING_SCHEDULE_ENABLED=false to disable.
SCORING_SCHEDULE_ENABLED=true
SCORING_SCHEDULE_TIME=06:00
SCORING_SCHEDULE_UNIVERSE=ALL

# ── Vite ─────────────────────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
